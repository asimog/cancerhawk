# Example environment variables for CancerHawk Railway deployment
# Copy to .env.railway or set in Railway dashboard

# OpenRouter API key for Hermes agent (required for autonomous runs)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# GitHub configuration for publishing results
GITHUB_REPO=asimog/cancerhawk
GITHUB_BRANCH=master
GITHUB_TOKEN=github_pat_...

# Git committer identity
GIT_COMMITTER_NAME=cancerhawk-worker
GIT_COMMITTER_EMAIL=worker@cancerhawk.local

# Public URLs
CANCERHAWK_PUBLIC_BASE_URL=https://www.cancerhawk.org
CANCERHAWK_BACKEND_URL=https://cancerhawk-production.up.railway.app
NEXT_PUBLIC_BACKEND_URL=https://cancerhawk-production.up.railway.app
CANCERHAWK_CORS_ORIGINS=https://cancerhawk.vercel.app,https://www.cancerhawk.org,https://cancerhawk.org,http://localhost:3000

# Optional: allow Railway to create a research block when no staged user job is waiting.
# Keep this off unless you intentionally want autonomous API spend.
HERMES_AUTO_GENERATE_ENABLED=false

# Optional: Vercel deploy hook for explicit website updates
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# Optional: YouTube downloader binary path
# YOUTUBE_DL_BINARY=yt-dlp
